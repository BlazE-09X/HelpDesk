<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/profile" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_worker_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Имя Исполнителя"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_worker_spec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Специализация"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tv_worker_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Рейтинг: 0.0 ⭐"
                android:textColor="#FFD700" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_worker_done_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сделано: 0"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"/>

            <ImageButton
                android:id="@+id/btn_delete_worker"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#F44336" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>