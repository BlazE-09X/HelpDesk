<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <View
        android:id="@+id/profile_header"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/figma_blue"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_avatar"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="30dp"
        android:src="@drawable/profile"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@android:color/white"
        android:padding="5dp"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/tv_admin_full_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Администратор"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/iv_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/profile_header"
        app:layout_constraintBottom_toTopOf="@id/btn_logout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/ll_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="20dp"
                android:layout_marginBottom="10dp">

                <TextView android:text="Login" android:textStyle="bold" android:textColor="@android:color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/tv_profile_login" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="login123" android:paddingBottom="8dp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginBottom="12dp" />

                <TextView android:text="Telephone" android:textStyle="bold" android:textColor="@android:color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/tv_profile_phone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="+7 (123) 456 7890" android:paddingBottom="8dp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginBottom="12dp" />

                <TextView android:text="Email" android:textStyle="bold" android:textColor="@android:color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/tv_profile_email" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="example@gmail.com" android:paddingBottom="8dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_manage_categories"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Управление категориями"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/figma_blue"
                android:layout_marginBottom="5dp" />

            <Button
                android:id="@+id/btn_change_email"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Изменить email"
                android:textAllCaps="false"
                android:textColor="@color/figma_blue"
                android:backgroundTint="@android:color/white"
                android:layout_marginBottom="5dp" />

            <Button
                android:id="@+id/btn_change_password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Изменить пароль"
                android:textAllCaps="false"
                android:textColor="@color/figma_blue"
                android:backgroundTint="@android:color/white" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_logout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="20dp"
        android:text="Выйти из системы"
        android:textColor="#FF4444"
        android:backgroundTint="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation_profile" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation_profile"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:menu="@menu/admin_bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>